# Copy this file to terraform.tfvars and fill in your values.
#   cp terraform.tfvars.example terraform.tfvars

# REQUIRED: OCID of the compartment where resources will be created.
compartment_ocid = "ocid1.compartment.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# REQUIRED: SSH public key content (single line, starts with "ssh-rsa" or "ssh-ed25519").
# Retrieve it from the Vault secret sec-linker5-vm-sshpubkey, or paste your own.
ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2E... your-key-here"

# GitHub token: leave empty for a public repo.
github_token = ""

# --- NETWORK MODE ---
# Landing zones usually block VCN creation, so the default reuses an existing subnet.
# Set this to the subnet OCID where the VM should live (same one as the existing VM).
create_network = false
subnet_ocid    = "ocid1.subnet.oc1.sa-bogota-1.xxxxxxxxxxxxxxxxxxxx"

# If you DO have networking permissions and want everything from scratch instead:
# create_network   = true
# assign_public_ip = true
# subnet_ocid      = ""   # not needed in that mode

# --- Everything below is optional (sensible defaults already set) ---

# region           = "sa-bogota-1"
# repo_url         = "https://github.com/co-eiv-devsecops/linker5.git"
# repo_branch      = "main"
# app_port         = 8080
# instance_shape   = "VM.Standard.E2.1.Micro"

# For an ARM Always-Free shape (more RAM/CPU) use instead:
# instance_shape      = "VM.Standard.A1.Flex"
# instance_ocpus      = 1
# instance_memory_gbs = 6
